rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == "pranab789000000@gmail.com";
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
    }

    // Cars collection
    match /cars/{carId} {
      // Public landing page needs to see car label/number
      allow read: if true; 
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.ownerId) || isAdmin();
    }

    // Alerts collection
    match /alerts/{alertId} {
      // Anyone can send an alert
      allow create: if true; 
      // Only owner or admin can read alerts
      allow read, list: if (isSignedIn() && resource.data.ownerId == request.auth.uid) || isAdmin();
    }
  }
}
